---
import './Style.css';

interface Props {
  id: number | string;
  name: string;
  price: number;
  oldPrice?: number | null;
  image: string;
  slug: string;
  isNew?: boolean;
  category?: string;
}

const { id, name, price, oldPrice, image, slug, isNew = false, category } = Astro.props;

const formatAZN = (val: number) =>
    new Intl.NumberFormat('az-AZ', {
      style: 'currency',
      currency: 'AZN',
      minimumFractionDigits: 2
    }).format(val);

const formattedPrice = formatAZN(price);
const formattedOldPrice = oldPrice ? formatAZN(oldPrice) : null;

const discountPercent = oldPrice ? Math.round(((oldPrice - price) / oldPrice) * 100) : 0;
---

<div class="pc-01 group" data-product-id={id}>
  <div class="pc-01-image-container">
    {isNew && <span class="pc-01-badge pc-01-badge-new">Yeni</span>}
    {discountPercent > 0 && <span class="pc-01-badge pc-01-badge-discount">-{discountPercent}%</span>}

    <a href={`/web/products/${id}-details`} class="pc-01-link">
      <img
          src={image || '/placeholder-product.png'}
          alt={name}
          class="pc-01-img"
          loading="lazy"
          decoding="async"
      />
    </a>

    <div class="pc-01-actions">
      <button class="pc-01-icon-btn" aria-label="İstək siyahısı">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      </button>
    </div>
  </div>

  <div class="pc-01-info">
    {category && <p class="pc-01-cat">{category}</p>}
    <a href={`/web/products/${id}-details`} class="pc-01-title" title={name}>{name}</a>

    <div class="pc-01-price-box">
      <span class="pc-01-current">{formattedPrice}</span>
      {formattedOldPrice && <span class="pc-01-old">{formattedOldPrice}</span>}
    </div>

    <button class="pc-01-btn" data-id={id}>
      <span>Səbətə At</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
    </button>
  </div>
</div>