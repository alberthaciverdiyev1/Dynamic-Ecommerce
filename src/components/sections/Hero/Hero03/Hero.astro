---
// src/components/sections/Hero03/Hero.astro
import './Style.css';

const slides = [
    {
        title: "Gələcəyin <br/> <span class='text-orange-600'>Texnologiyası</span>",
        subtitle: "Yeni iPhone 17 Pro",
        desc: "Süni zəka ilə gücləndirilmiş ən yeni prosessor və mükəmməl kamera sistemi.",
        image: "https://images.unsplash.com/photo-1616348436168-de43ad0db179?q=80&w=1200",
        link: "/web/products/iphone-17",
        btnText: "İndi Sifariş Et"
    },
    {
        title: "Musiqini <br/> <span class='text-blue-600'>Hiss Et</span>",
        subtitle: "Premium Audio",
        desc: "Yüksək keyfiyyətli səs və səs-küyün ləğvi. Musiqidən həzz alın.",
        image: "https://images.unsplash.com/photo-1546435770-a3e4267039a6?q=80&w=1200",
        link: "/web/category/audio",
        btnText: "Kolleksiyaya Bax"
    }
];
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="hero-v3">
    <div class="swiper mainHeroSwiper">
        <div class="swiper-wrapper">
            {slides.map((slide) => (
                    <div class="swiper-slide">
                        <div class="hero-v3-bg">
                            <img src={slide.image} alt="" class="hero-v3-img" />
                            <div class="hero-v3-overlay"></div>
                        </div>

                        <div class="container mx-auto px-4 h-full relative z-10">
                            <div class="flex flex-col justify-center h-full max-w-2xl">
                                <span class="slide-subtitle" data-swiper-parallax="-300">{slide.subtitle}</span>
                                <h1 class="slide-title" data-swiper-parallax="-500" set:html={slide.title} />
                                <p class="slide-desc" data-swiper-parallax="-700">{slide.desc}</p>
                                <div class="slide-actions" data-swiper-parallax="-900">
                                    <a href={slide.link} class="hero-v3-btn">{slide.btnText}</a>
                                </div>
                            </div>
                        </div>
                    </div>
            ))}
        </div>

        <div class="swiper-pagination"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
    </div>
</section>

<script>
    import './Script.js';
</script>