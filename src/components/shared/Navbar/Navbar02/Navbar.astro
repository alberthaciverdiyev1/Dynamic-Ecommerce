---
// src/components/shared/navbar/Navbar02/Navbar.astro
import './Style.css';
---

<nav class="nav-v2" data-navbar="navbar02">
    <div class="nav-v2-container container mx-auto px-4">

        <div class="nav-v2-left">
            <a href="/web" class="nav-v2-logo">
                MYSTORE<span class="text-orange-600">.</span>
            </a>
        </div>

        <div class="nav-v2-center hidden lg:flex">
            <div class="search-box-v2">
                <input type="text" placeholder="Məhsul, marka və ya kateqoriya axtar..." id="nav-search-v2" />
                <button class="search-btn-v2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </button>
            </div>
        </div>

        <div class="nav-v2-right">
            <div class="nav-v2-icons flex items-center space-x-6">
                <a href="/web/account/profile" class="nav-icon-link group">
                    <span class="icon-label hidden md:block">Giriş</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-orange-600"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </a>

                <a href="/web/wishlist" class="nav-icon-link relative">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                </a>

                <a href="/web/cart" class="nav-cart-btn-v2">
                    <div class="cart-icon-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        <span class="cart-badge-v2">0</span>
                    </div>
                    <span class="ml-2 font-bold hidden sm:block">0.00 AZN</span>
                </a>
            </div>
        </div>

    </div>
</nav>

<script>
    import './Script.js';
</script>