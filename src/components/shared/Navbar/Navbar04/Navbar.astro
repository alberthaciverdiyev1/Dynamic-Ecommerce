---
import './Style.css';
---

<nav class="nav-v4" data-navbar="navbar04">
    <div class="container mx-auto px-4 py-4 flex items-center gap-6">

        <div class="flex-shrink-0">
            <a href="/web">
                <img src="https://tesoro.az/assets/web/images/tesero-logo-png.png" alt="İkili İki" class="h-12 w-auto" />
            </a>
        </div>

        <button class="nav-v4-cat-btn group">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            <span>Məhsullar</span>
        </button>

        <div class="flex-grow max-w-xl relative">
            <input type="text" placeholder="Axtarış..." class="nav-v4-search-input" />
            <button class="nav-v4-search-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </button>
        </div>

        <div class="hidden lg:flex items-center space-x-6 text-sm font-medium text-gray-600">
            <a href="/web/products" class="hover:text-black">Mehsullar</a>
            <a href="/web/about" class="hover:text-black">Haqqımızda</a>
            <a href="/web/blog" class="hover:text-black">Blog</a>
            <a href="/web/contact" class="hover:text-black">Bizimlə əlaqə</a>
        </div>

        <div class="nav-v4-lang">
            <button class="flex items-center gap-2 text-sm font-medium">
                <img src="https://flagcdn.com/w20/gb.png" alt="English" class="w-5 h-auto rounded-sm" />
                İngilis dili
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
        </div>

        <div class="flex-shrink-0">
            <a href="tel:+994709990569" class="nav-v4-phone-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                +994709990569
            </a>
        </div>

    </div>
</nav>

