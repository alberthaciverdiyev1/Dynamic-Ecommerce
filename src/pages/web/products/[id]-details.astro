---
import WebLayout from '../../../layouts/WebLayout.astro';

const { id } = Astro.params;

const response = await fetch(`https://teymurstore.az/api/product/${id}`);
const result = await response.json();
const product = result.data;

if (!product) return Astro.redirect('/404');

// Fiyat hesaplamaları
const hasDiscount = product.discount > 0;
const currentPrice = product.price;
const oldPrice = hasDiscount ? (product.price + product.discount) : null;

// Formatlama
const formatAZN = (val: number) =>
    new Intl.NumberFormat('az-AZ', { style: 'currency', currency: 'AZN' }).format(val);
---

<WebLayout title={`${product.title} | TeymurStore`}>
    <div class="container mx-auto px-4 py-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

            <div class="space-y-4">
                <div class="aspect-square rounded-2xl overflow-hidden bg-gray-100 border border-gray-200">
                    <img
                            src={product.images[0]?.image_path}
                            alt={product.title}
                            class="w-full h-full object-contain mix-blend-multiply p-8"
                    />
                </div>
                <div class="grid grid-cols-4 gap-4">
                    {product.images.slice(1).map((img: any) => (
                            <div class="aspect-square rounded-lg border border-gray-200 overflow-hidden cursor-pointer hover:border-orange-500 transition-colors">
                                <img src={img.image_path} class="w-full h-full object-cover" />
                            </div>
                    ))}
                </div>
            </div>

            <div class="flex flex-col">
                <nav class="text-sm text-gray-500 mb-4">
                    <a href="/" class="hover:text-orange-500">Ana Səhifə</a> /
                    <a href={`/category/${product.category.id}`} class="hover:text-orange-500 ml-1">{product.category.name}</a>
                </nav>

                <h1 class="text-3xl font-bold text-gray-900 mb-2">{product.title}</h1>
                <p class="text-sm text-gray-400 mb-6">SKU: {product.sku}</p>

                <div class="flex items-center gap-4 mb-8">
                    <span class="text-4xl font-bold text-orange-600">{formatAZN(currentPrice)}</span>
                    {hasDiscount && (
                            <span class="text-xl text-gray-400 line-through">{formatAZN(oldPrice)}</span>
                    )}
                </div>

                <div class="prose prose-sm text-gray-600 mb-8 whitespace-pre-line">
                    {product.description}
                </div>

                <div class="mt-auto space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="flex border border-gray-300 rounded-lg">
                            <button class="px-4 py-2 hover:bg-gray-100">-</button>
                            <input type="number" value="1" class="w-12 text-center border-x border-gray-300 focus:outline-none" />
                            <button class="px-4 py-2 hover:bg-gray-100">+</button>
                        </div>
                        <p class="text-sm text-gray-500">Stokda: {product.stock_count} ədəd</p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <button class="bg-orange-600 text-white py-4 rounded-xl font-bold hover:bg-orange-700 transition-colors shadow-lg shadow-orange-200">
                            Səbətə Əlavə Et
                        </button>
                        <button class="border border-gray-300 py-4 rounded-xl font-bold hover:bg-gray-50 transition-colors">
                            İstək Siyahısı
                        </button>
                    </div>
                </div>
            </div>
        </div>

        {product.videos.length > 0 && (
                <div class="mt-20">
                    <h2 class="text-2xl font-bold mb-6">Məhsul Videosu</h2>
                    <div class="max-w-3xl mx-auto rounded-2xl overflow-hidden shadow-2xl">
                        <video controls class="w-full">
                            <source src={product.videos[0].video_path} type="video/mp4" />
                        </video>
                    </div>
                </div>
        )}
    </div>
</WebLayout>